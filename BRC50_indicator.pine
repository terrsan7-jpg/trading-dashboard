// This Pine Script™ source code is subject to the terms of the Mozilla Public License 2.0
// © Liquidity Sweep + Displacement Indicator (SMC)
//@version=5
indicator("Liquidity Sweep Signals", shorttitle="LiqSweep", overlay=true, max_labels_count=500)

// ═════════════════════════════════════════════════════════════
// HOW IT WORKS
// ═════════════════════════════════════════════════════════════
// 1. FIND LIQUIDITY — Detect recent pivot highs/lows (where stops sit)
// 2. DETECT SWEEP  — Price wicks beyond a pivot (stop hunt)
// 3. DISPLACEMENT  — A strong candle reverses back with body + volume
// 4. TREND FILTER  — Only long above EMA 50, short below EMA 50
// 5. SIGNAL        — BUY/SELL label with suggested SL & TP levels

// ═════════════════════════════════════════════════════════════
// INPUTS
// ═════════════════════════════════════════════════════════════

// ── Pivot / Swing Detection ──
pivotLen        = input.int(5,      "Pivot Lookback (left & right bars)", minval=2, maxval=20, group="Swing Detection",
     tooltip="Number of bars on each side to confirm a swing high/low. Higher = stronger levels, fewer signals.")
maxPivotAge     = input.int(100,    "Max Pivot Age (bars)",              minval=20, maxval=500, group="Swing Detection",
     tooltip="Ignore pivots older than this many bars")

// ── EMA Trend Filter ──
emaLength       = input.int(50,     "EMA Length",                        minval=1,   group="EMA Trend Filter")
emaColor        = input.color(color.new(color.orange, 0), "EMA Color",  group="EMA Trend Filter")

// ── Displacement Candle ──
dispBodyMult    = input.float(1.5,  "Displacement Body Multiplier",      minval=1.0, step=0.1, group="Displacement",
     tooltip="Displacement candle body must be this × the average body size")
dispVolMult     = input.float(1.3,  "Displacement Volume Multiplier",    minval=1.0, step=0.1, group="Displacement",
     tooltip="Displacement candle volume must be this × the average volume")
bodyAvgLen      = input.int(20,     "Body/Volume Average Lookback",      minval=5,   group="Displacement")

// ── Risk Management (for plotted SL/TP levels) ──
slPadATR        = input.float(0.3,  "SL Padding (ATR ×)",               minval=0.0, step=0.1, group="Risk Management",
     tooltip="Extra padding beyond the sweep wick for the stop loss")
tpRatio         = input.float(2.0,  "Risk:Reward Ratio",                minval=0.5, step=0.1, group="Risk Management")

// ── RSI Filter (optional) ──
useRSI          = input.bool(false, "Enable RSI Filter",                 group="RSI Filter")
rsiLen          = input.int(14,     "RSI Length",                        minval=2,   group="RSI Filter")
rsiOB           = input.int(70,     "Skip BUY above RSI",               minval=50,  group="RSI Filter")
rsiOS           = input.int(30,     "Skip SELL below RSI",              maxval=50,  group="RSI Filter")

// ── Session Filter (optional) ──
useSess         = input.bool(false, "Enable Session Filter",             group="Session Filter")
sessStart       = input.session("0930-1600", "Trading Session (exchange TZ)", group="Session Filter",
     tooltip="Only take trades during this session window")

// ── Visuals ──
showLabels      = input.bool(true,  "Show Signal Labels",                group="Visuals")
showPivots      = input.bool(true,  "Show Pivot Levels",                 group="Visuals")
showSLTP        = input.bool(true,  "Show SL/TP Lines",                 group="Visuals")
bullColor       = input.color(color.new(#00C853, 0), "Bullish Color",   group="Visuals")
bearColor       = input.color(color.new(#FF1744, 0), "Bearish Color",   group="Visuals")
pivotColor      = input.color(color.new(#FFD600, 0), "Pivot Color",     group="Visuals")

// ═════════════════════════════════════════════════════════════
// CALCULATIONS
// ═════════════════════════════════════════════════════════════

ema50       = ta.ema(close, emaLength)
atrVal      = ta.atr(14)
rsiVal      = ta.rsi(close, rsiLen)
bodySize    = math.abs(close - open)
avgBody     = ta.sma(bodySize, bodyAvgLen)
avgVol      = ta.sma(volume, bodyAvgLen)

inSession   = not useSess or not na(time(timeframe.period, sessStart))

// ═════════════════════════════════════════════════════════════
// STEP 1: DETECT PIVOT HIGHS & LOWS
// ═════════════════════════════════════════════════════════════

ph = ta.pivothigh(high, pivotLen, pivotLen)
pl = ta.pivotlow(low, pivotLen, pivotLen)

var float[] pivotHighs    = array.new_float(0)
var int[]   pivotHighBars = array.new_int(0)
var float[] pivotLows     = array.new_float(0)
var int[]   pivotLowBars  = array.new_int(0)

if not na(ph)
    array.unshift(pivotHighs, ph)
    array.unshift(pivotHighBars, bar_index - pivotLen)
    if array.size(pivotHighs) > 5
        array.pop(pivotHighs)
        array.pop(pivotHighBars)

if not na(pl)
    array.unshift(pivotLows, pl)
    array.unshift(pivotLowBars, bar_index - pivotLen)
    if array.size(pivotLows) > 5
        array.pop(pivotLows)
        array.pop(pivotLowBars)

// ═════════════════════════════════════════════════════════════
// STEP 2: DETECT LIQUIDITY SWEEP
// ═════════════════════════════════════════════════════════════

var float sweptLevel     = na
var float sweepWickLow   = na
var float sweepWickHigh  = na
var bool  bullSweepFired = false
var bool  bearSweepFired = false

bullSweepFired := false
bearSweepFired := false
sweptLevel     := na
sweepWickLow   := na
sweepWickHigh  := na

// Bullish sweep (sweep of pivot low)
if array.size(pivotLows) > 0
    for i = 0 to math.min(array.size(pivotLows) - 1, 4)
        lvl    = array.get(pivotLows, i)
        lvlBar = array.get(pivotLowBars, i)
        age    = bar_index - lvlBar
        if age <= maxPivotAge and age > 0 and low < lvl and close > lvl
            sweptLevel     := lvl
            sweepWickLow   := low
            bullSweepFired := true
            array.remove(pivotLows, i)
            array.remove(pivotLowBars, i)
            break

// Bearish sweep (sweep of pivot high)
if array.size(pivotHighs) > 0 and not bullSweepFired
    for i = 0 to math.min(array.size(pivotHighs) - 1, 4)
        lvl    = array.get(pivotHighs, i)
        lvlBar = array.get(pivotHighBars, i)
        age    = bar_index - lvlBar
        if age <= maxPivotAge and age > 0 and high > lvl and close < lvl
            sweptLevel     := lvl
            sweepWickHigh  := high
            bearSweepFired := true
            array.remove(pivotHighs, i)
            array.remove(pivotHighBars, i)
            break

// ═════════════════════════════════════════════════════════════
// STEP 3: DISPLACEMENT CONFIRMATION
// ═════════════════════════════════════════════════════════════

isStrongBody = bodySize > avgBody * dispBodyMult
isStrongVol  = volume > avgVol * dispVolMult

bullDisplacement = bullSweepFired and close > open and isStrongBody and isStrongVol
bearDisplacement = bearSweepFired and close < open and isStrongBody and isStrongVol

// ═════════════════════════════════════════════════════════════
// STEP 4: APPLY FILTERS
// ═════════════════════════════════════════════════════════════

emaBullOK = close > ema50
emaBearOK = close < ema50
rsiBullOK = not useRSI or rsiVal < rsiOB
rsiBearOK = not useRSI or rsiVal > rsiOS

bullSignal = bullDisplacement and emaBullOK and rsiBullOK and inSession
bearSignal = bearDisplacement and emaBearOK and rsiBearOK and inSession

// ═════════════════════════════════════════════════════════════
// SL / TP LEVELS (for visual reference)
// ═════════════════════════════════════════════════════════════

var float sigSL = na
var float sigTP = na
var int   sigDir = 0  // 1 = long, -1 = short

if bullSignal
    sigSL  := sweepWickLow - atrVal * slPadATR
    slDist  = close - sigSL
    sigTP  := close + slDist * tpRatio
    sigDir := 1

if bearSignal
    sigSL  := sweepWickHigh + atrVal * slPadATR
    slDist  = sigSL - close
    sigTP  := close - slDist * tpRatio
    sigDir := -1

// Clear SL/TP after price hits either level
if sigDir == 1 and (low <= sigSL or high >= sigTP)
    sigSL  := na
    sigTP  := na
    sigDir := 0

if sigDir == -1 and (high >= sigSL or low <= sigTP)
    sigSL  := na
    sigTP  := na
    sigDir := 0

// ═════════════════════════════════════════════════════════════
// PLOTTING
// ═════════════════════════════════════════════════════════════

// EMA
plot(ema50, "EMA 50", color=emaColor, linewidth=2)

// Pivot markers
plotshape(showPivots and not na(ph), title="Pivot High", style=shape.triangledown,
     location=location.abovebar, color=color.new(pivotColor, 50), size=size.tiny, offset=-pivotLen)
plotshape(showPivots and not na(pl), title="Pivot Low", style=shape.triangleup,
     location=location.belowbar, color=color.new(pivotColor, 50), size=size.tiny, offset=-pivotLen)

// Entry signals
plotshape(showLabels and bullSignal, title="BUY", text="BUY",
     style=shape.labelup, location=location.belowbar, color=bullColor,
     textcolor=color.white, size=size.normal)
plotshape(showLabels and bearSignal, title="SELL", text="SELL",
     style=shape.labeldown, location=location.abovebar, color=bearColor,
     textcolor=color.white, size=size.normal)

// SL / TP reference lines
plot(showSLTP and sigDir == 1 ? sigSL : na, "Long SL",
     color=color.new(bearColor, 40), style=plot.style_linebr, linewidth=1)
plot(showSLTP and sigDir == 1 ? sigTP : na, "Long TP",
     color=color.new(bullColor, 40), style=plot.style_linebr, linewidth=1)
plot(showSLTP and sigDir == -1 ? sigSL : na, "Short SL",
     color=color.new(bearColor, 40), style=plot.style_linebr, linewidth=1)
plot(showSLTP and sigDir == -1 ? sigTP : na, "Short TP",
     color=color.new(bullColor, 40), style=plot.style_linebr, linewidth=1)

// Highlight signal candles
barcolor(bullSignal ? color.new(bullColor, 30) : bearSignal ? color.new(bearColor, 30) : na)

// ═════════════════════════════════════════════════════════════
// ALERTS
// ═════════════════════════════════════════════════════════════
alertcondition(bullSignal, title="LiqSweep BUY",
     message="LiqSweep: BUY on {{ticker}} ({{interval}}) — Sweep + displacement confirmed")
alertcondition(bearSignal, title="LiqSweep SELL",
     message="LiqSweep: SELL on {{ticker}} ({{interval}}) — Sweep + displacement confirmed")

// ═════════════════════════════════════════════════════════════
// INFO TABLE
// ═════════════════════════════════════════════════════════════
var table t = table.new(position.top_right, 2, 7, bgcolor=color.new(color.black, 85), border_width=1)

if barstate.islast
    table.cell(t, 0, 0, "LiqSweep",            text_color=color.white, text_size=size.small)
    table.cell(t, 1, 0, "",                      text_color=color.white, text_size=size.small)

    table.cell(t, 0, 1, "Trend (EMA)",          text_color=color.gray,  text_size=size.tiny)
    table.cell(t, 1, 1, close > ema50 ? "BULL ▲" : "BEAR ▼",
         text_color=close > ema50 ? bullColor : bearColor, text_size=size.tiny)

    table.cell(t, 0, 2, "Body Strength",        text_color=color.gray,  text_size=size.tiny)
    table.cell(t, 1, 2, str.tostring(bodySize / avgBody, "#.##") + "x",
         text_color=isStrongBody ? bullColor : color.gray, text_size=size.tiny)

    table.cell(t, 0, 3, "Vol Strength",         text_color=color.gray,  text_size=size.tiny)
    table.cell(t, 1, 3, str.tostring(volume / avgVol, "#.##") + "x",
         text_color=isStrongVol ? bullColor : color.gray, text_size=size.tiny)

    rsiTxt = useRSI ? str.tostring(rsiVal, "#.#") : "OFF"
    table.cell(t, 0, 4, "RSI",                  text_color=color.gray,  text_size=size.tiny)
    table.cell(t, 1, 4, rsiTxt,
         text_color=useRSI and rsiVal > rsiOB ? bearColor : useRSI and rsiVal < rsiOS ? bullColor : color.white, text_size=size.tiny)

    table.cell(t, 0, 5, "Pivot Highs",          text_color=color.gray,  text_size=size.tiny)
    table.cell(t, 1, 5, str.tostring(array.size(pivotHighs)),
         text_color=pivotColor, text_size=size.tiny)

    table.cell(t, 0, 6, "Pivot Lows",           text_color=color.gray,  text_size=size.tiny)
    table.cell(t, 1, 6, str.tostring(array.size(pivotLows)),
         text_color=pivotColor, text_size=size.tiny)
