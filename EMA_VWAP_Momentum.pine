// © EMA Ribbon + VWAP Momentum Day Trading Indicator

//@version=5
indicator("EMA VWAP Momentum - Options Day Trader", overlay=true, max_labels_count=500, max_lines_count=500, max_boxes_count=50)

// ─── INPUTS ───────────────────────────────────────────────────────────────────

// EMA Settings
emaFastLen   = input.int(9,   "Fast EMA Length",   minval=1, group="EMAs")
emaSlowLen   = input.int(21,  "Slow EMA Length",   minval=1, group="EMAs")
emaTrendLen  = input.int(200, "Trend EMA Length",   minval=1, group="EMAs")

// RSI Settings
rsiLen       = input.int(14,  "RSI Length",         minval=1,  group="RSI")
rsiLongLo    = input.int(50,  "RSI Long Min",       minval=0,  maxval=100, group="RSI")
rsiLongHi    = input.int(75,  "RSI Long Max",       minval=0,  maxval=100, group="RSI")
rsiShortLo   = input.int(25,  "RSI Short Min",      minval=0,  maxval=100, group="RSI")
rsiShortHi   = input.int(50,  "RSI Short Max",      minval=0,  maxval=100, group="RSI")

// Volume Settings
volAvgLen    = input.int(20,  "Volume Average Length", minval=1, group="Volume")

// VWAP Settings
vwapStdMult  = input.float(1.0, "VWAP Std Dev Multiplier", minval=0.1, step=0.1, group="VWAP")

// Risk Settings
targetPct    = input.float(0.5, "Take Profit %",    minval=0.1, step=0.1, group="Risk") / 100
stopPct      = input.float(0.3, "Stop Loss %",      minval=0.1, step=0.1, group="Risk") / 100

// Time Window (ET)
startHour    = input.int(9,   "Session Start Hour (ET)",   minval=0, maxval=23, group="Time Window")
startMin     = input.int(30,  "Session Start Minute (ET)", minval=0, maxval=59, group="Time Window")
endHour      = input.int(11,  "Session End Hour (ET)",     minval=0, maxval=23, group="Time Window")
endMin       = input.int(30,  "Session End Minute (ET)",   minval=0, maxval=59, group="Time Window")

// Signal Settings
cooldownBars = input.int(5,   "Min Bars Between Signals",  minval=1, group="Signals")
maxSignals   = input.int(3,   "Max Signals Per Day",       minval=1, group="Signals")

// ─── CALCULATIONS ─────────────────────────────────────────────────────────────

// EMAs
emaFast  = ta.ema(close, emaFastLen)
emaSlow  = ta.ema(close, emaSlowLen)
emaTrend = ta.ema(close, emaTrendLen)

// RSI
rsiVal = ta.rsi(close, rsiLen)

// Volume
volAvg    = ta.sma(volume, volAvgLen)
volAbove  = volume > volAvg

// VWAP with standard deviation bands
vwapVal      = ta.vwap(hlc3)
// Manual VWAP std dev calculation
var float sumVol       = 0.0
var float sumVolPrice  = 0.0
var float sumVolPrice2 = 0.0

if ta.change(time("D")) != 0
    sumVol       := 0.0
    sumVolPrice  := 0.0
    sumVolPrice2 := 0.0

sumVol       += volume
sumVolPrice  += volume * hlc3
sumVolPrice2 += volume * hlc3 * hlc3

vwapMean  = sumVol > 0 ? sumVolPrice / sumVol : hlc3
variance  = sumVol > 0 ? (sumVolPrice2 / sumVol) - (vwapMean * vwapMean) : 0.0
vwapStd   = math.sqrt(math.max(variance, 0))
vwapUpper = vwapVal + vwapStdMult * vwapStd
vwapLower = vwapVal - vwapStdMult * vwapStd

// EMA Crosses
emaBullCross = ta.crossover(emaFast, emaSlow)
emaBearCross = ta.crossunder(emaFast, emaSlow)

// ─── TIME WINDOW ──────────────────────────────────────────────────────────────

etTime       = timestamp("America/New_York", year, month, dayofmonth, 0, 0, 0)
nowET_ms     = time - etTime + timestamp("America/New_York", year, month, dayofmonth, 0, 0, 0)
// Use hour/minute in ET timezone
etHour       = hour(time, "America/New_York")
etMinute     = minute(time, "America/New_York")
etTotalMin   = etHour * 60 + etMinute
startTotalMin = startHour * 60 + startMin
endTotalMin   = endHour * 60 + endMin

inSession    = etTotalMin >= startTotalMin and etTotalMin < endTotalMin
newDay       = ta.change(time("D")) != 0

// ─── SIGNAL STATE TRACKING ────────────────────────────────────────────────────

var int   signalsToday    = 0
var int   barsSinceSig    = cooldownBars + 1  // allow first signal
var int   tradeDir        = 0    // 1 = long, -1 = short, 0 = flat
var float entryPrice      = na
var float targetPrice     = na
var float stopPrice       = na
var line  entryLine       = na
var line  targetLine      = na
var line  stopLine        = na

// Reset daily counter
if newDay
    signalsToday := 0

barsSinceSig += 1

canSignal = inSession and barsSinceSig > cooldownBars and signalsToday < maxSignals and tradeDir == 0

// ─── ENTRY CONDITIONS ─────────────────────────────────────────────────────────

longEntry = canSignal and
     close > vwapVal and
     emaBullCross and
     close > emaTrend and
     rsiVal >= rsiLongLo and rsiVal <= rsiLongHi and
     volAbove

shortEntry = canSignal and
     close < vwapVal and
     emaBearCross and
     close < emaTrend and
     rsiVal >= rsiShortLo and rsiVal <= rsiShortHi and
     volAbove

// ─── EXIT CONDITIONS ──────────────────────────────────────────────────────────

longExit = tradeDir == 1 and (
     close >= targetPrice or
     close <= stopPrice or
     close >= vwapUpper or
     ta.crossunder(emaFast, emaSlow) or
     close < vwapVal)

shortExit = tradeDir == -1 and (
     close <= targetPrice or
     close >= stopPrice or
     close <= vwapLower or
     ta.crossover(emaFast, emaSlow) or
     close > vwapVal)

// ─── EXECUTE SIGNALS ──────────────────────────────────────────────────────────

if longEntry
    tradeDir     := 1
    entryPrice   := close
    targetPrice  := close * (1 + targetPct)
    stopPrice    := close * (1 - stopPct)
    signalsToday += 1
    barsSinceSig := 0
    entryLine    := line.new(bar_index, entryPrice, bar_index + 20, entryPrice, color=color.white, style=line.style_dashed, width=1)
    targetLine   := line.new(bar_index, targetPrice, bar_index + 20, targetPrice, color=color.lime, style=line.style_dotted, width=1)
    stopLine     := line.new(bar_index, stopPrice, bar_index + 20, stopPrice, color=color.red, style=line.style_dotted, width=1)
    label.new(bar_index, low, "CALL ▲", style=label.style_label_up, color=color.green, textcolor=color.white, size=size.normal)

if shortEntry
    tradeDir     := -1
    entryPrice   := close
    targetPrice  := close * (1 - targetPct)
    stopPrice    := close * (1 + stopPct)
    signalsToday += 1
    barsSinceSig := 0
    entryLine    := line.new(bar_index, entryPrice, bar_index + 20, entryPrice, color=color.white, style=line.style_dashed, width=1)
    targetLine   := line.new(bar_index, targetPrice, bar_index + 20, targetPrice, color=color.lime, style=line.style_dotted, width=1)
    stopLine     := line.new(bar_index, stopPrice, bar_index + 20, stopPrice, color=color.red, style=line.style_dotted, width=1)
    label.new(bar_index, high, "PUT ▼", style=label.style_label_down, color=color.red, textcolor=color.white, size=size.normal)

if longExit or shortExit
    exitY = tradeDir == 1 ? high : low
    exitStyle = tradeDir == 1 ? label.style_label_down : label.style_label_up
    label.new(bar_index, exitY, "EXIT", style=exitStyle, color=color.white, textcolor=color.black, size=size.normal)
    tradeDir    := 0
    entryPrice  := na
    targetPrice := na
    stopPrice   := na

// ─── PLOTS ────────────────────────────────────────────────────────────────────

// EMA Ribbon
fastPlot = plot(emaFast, "EMA Fast", color=color.new(color.aqua, 0), linewidth=1)
slowPlot = plot(emaSlow, "EMA Slow", color=color.new(color.orange, 0), linewidth=1)
fill(fastPlot, slowPlot, color=emaFast > emaSlow ? color.new(color.aqua, 85) : color.new(color.orange, 85))

// EMA 200
plot(emaTrend, "EMA 200", color=color.new(color.yellow, 0), linewidth=2)

// VWAP and bands
plot(vwapVal,   "VWAP",       color=color.new(color.white, 0),  linewidth=2, style=plot.style_circles)
plot(vwapUpper, "VWAP Upper", color=color.new(color.gray, 50),  linewidth=1, style=plot.style_cross)
plot(vwapLower, "VWAP Lower", color=color.new(color.gray, 50),  linewidth=1, style=plot.style_cross)

// ─── VOLUME BAR COLORING ──────────────────────────────────────────────────────

barcolor(volAbove ? color.new(color.lime, 30) : color.new(color.gray, 30))

// ─── BACKGROUND COLORING ─────────────────────────────────────────────────────

sessionBg = not inSession ? color.new(color.gray, 92) : close > vwapVal ? color.new(color.green, 94) : color.new(color.red, 94)
bgcolor(sessionBg, title="Session / VWAP Background")

// ─── INFO TABLE ───────────────────────────────────────────────────────────────

var table infoBox = table.new(position.top_right, 2, 4, bgcolor=color.new(color.black, 20), border_width=1, border_color=color.gray)

statusText = tradeDir == 1 ? "LONG (CALL)" : tradeDir == -1 ? "SHORT (PUT)" : "FLAT"
statusClr  = tradeDir == 1 ? color.lime : tradeDir == -1 ? color.red : color.gray
sessionTxt = inSession ? "ACTIVE" : "CLOSED"
sessionClr = inSession ? color.lime : color.red

if barstate.islast
    table.cell(infoBox, 0, 0, "Signal",    text_color=color.white, text_size=size.small)
    table.cell(infoBox, 1, 0, statusText,   text_color=statusClr,  text_size=size.small)
    table.cell(infoBox, 0, 1, "Signals Today", text_color=color.white, text_size=size.small)
    table.cell(infoBox, 1, 1, str.tostring(signalsToday) + " / " + str.tostring(maxSignals), text_color=color.white, text_size=size.small)
    table.cell(infoBox, 0, 2, "Session",    text_color=color.white, text_size=size.small)
    table.cell(infoBox, 1, 2, sessionTxt,    text_color=sessionClr, text_size=size.small)
    table.cell(infoBox, 0, 3, "RSI",        text_color=color.white, text_size=size.small)
    table.cell(infoBox, 1, 3, str.tostring(rsiVal, "#.0"), text_color=color.white, text_size=size.small)

// ─── RSI SEPARATE PANE ───────────────────────────────────────────────────────

// Note: RSI is plotted using a separate indicator added to the chart,
// or you can uncomment below and use this as a separate pane copy.
// Pine Script v5 does not allow a single indicator to draw in both
// the main chart (overlay=true) and a separate pane simultaneously.
// Workaround: RSI value is shown in the info table above.

// ─── ALERT CONDITIONS ─────────────────────────────────────────────────────────

alertcondition(longEntry,  title="CALL Entry",  message="CALL ▲ Signal — EMA VWAP Momentum long entry triggered")
alertcondition(shortEntry, title="PUT Entry",    message="PUT ▼ Signal — EMA VWAP Momentum short entry triggered")
alertcondition(longExit or shortExit, title="EXIT Signal", message="EXIT — Trade exit condition triggered")
